# AgentQA env template
#
# Copy this file to:
# - backend/.env (recommended for backend secrets)
# - frontend/.env (for VITE_API_BASE only)
#
# Never commit real keys. `.gitignore` blocks `.env` files and generated reports.

# Backend
GEMINI_API_KEY=your_google_gemini_api_key_here
GITHUB_TOKEN=your_github_pat_here  # optional — raises GitHub API rate limit

# Optional runtime toggles
AGENTQA_ENABLE_MUTATION=1   # set 1 to compute mutmut score
AGENTQA_DOCKER_EXEC=1       # set 1 to attempt Docker isolation for execution

# Frontend (create `frontend/.env`)
# VITE_API_BASE=http://localhost:8000
